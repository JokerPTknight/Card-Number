luhn_check() {
    local num=$1
    local sum=0
    local parity=$(( ${#num} % 2 ))
    
    for (( i=0; i<${#num}; i++ )); do
        local digit=${num:$i:1}
        if [ $(( (i + parity) % 2 )) -eq 0 ]; then
            digit=$((digit * 2))
            digit=$((digit / 10 + digit % 10))
        fi
        sum=$((sum + digit))
    done
    
    [ $((sum % 10)) -eq 0 ]
}

generate_cc() {
    local bin=$1
    local length=${2:-16}
    local count=$3
    
    # BIN Info Database (real IIN ranges)
    declare -A bin_info=(
        ["34"]="AMEX | American Express | Travel"
        ["37"]="AMEX | American Express | Travel" 
        ["4"]="VISA | Visa | Classic/Debit"
        ["5"]="MC | Mastercard | Standard"
        ["6"]="DISC | Discover | Retail"
    )
    
    local brand="${bin_info[$bin]:-Unknown}"
    
    echo -e "${PURPLE}[$bin] $brand | Length: $length | Count: $count${NC}"
    
    local valid_count=0
    for ((i=0; i<count; i++)); do
        # Generate random suffix
        local suffix=$(printf "%0$((length - ${#bin} - 1))d" $((RANDOM % 10**((length - ${#bin} - 1)))))
        local cc="${bin}${suffix}"
        
        # Generate check digit
        local sum=0
        local parity=$((length % 2 ))
        for ((j=0; j<length; j++)); do
            local digit=${cc:$j:1}
            if [ $(( (j + parity) % 2 )) -eq 0 ]; then
                digit=$((digit * 2))
                digit=$((digit / 10 + digit % 10))
            fi
            sum=$((sum + digit))
        done
        local check_digit=$(( (10 - sum % 10) % 10 ))
        local full_cc="${cc}${check_digit}"
        
        if luhn_check "$full_cc"; then
            ((valid_count++))
            local cvv=$(printf "%03d" $((RANDOM % 1000)))
            local exp_month=$(printf "%02d" $((RANDOM % 12 + 1)))
            local exp_year=$(( (RANDOM % 5 + 2025) % 100 + 25 ))
            printf "${GREEN}%-20s | %04d/%02d | %s${NC}\n" "$full_cc" "$exp_year" "$exp_month" "$cvv"
        fi
